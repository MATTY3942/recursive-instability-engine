CAN Tfrom fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
import random

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/")
def root():
    return {"status": "ok"}

@app.get("/global")
def global_instability():
    state = 0.02 + random.uniform(0, 0.02)
    threshold = 0.03

    value = int((state / threshold) * 100)
    status = "Critical" if state > threshold else "Calm"

    return {
        "value": value,
        "state": round(state, 4),
        "threshold": threshold,
        "status": status
    }

@app.get("/sectors")
def sector_instability():
    return {
        "semiconductors": 100,
        "crypto": 12.7,
        "megacap": 100
    }

@app.get("/history")
def history():
    return [
        {"date": "2007-07", "value": 20},
        {"date": "2008-03", "value": 60},
        {"date": "2008-09", "value": 100},
        {"date": "2009-01", "value": 40},
    ]

